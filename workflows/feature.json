{
  "name": "feature",
  "services": [
    { "name": "servers", "script": "services/start-servers.sh", "readyEvent": "tunnel_ready" },
    { "name": "webhook", "script": "services/watch-feedback.sh" }
  ],
  "workflow": [
    {
      "id": "fetch-ticket",
      "type": "script",
      "script": "scripts/fetch-ticket.js",
      "stateWrites": ["ticket_identifier", "ticket_url", "ticket_title", "plan_status"]
    },
    {
      "id": "branch",
      "type": "script",
      "script": "scripts/branch.sh",
      "stateReads": ["ticket_identifier", "ticket_title"],
      "stateWrites": ["branch"]
    },
    {
      "id": "analyze-ticket",
      "type": "claude-tui",
      "skill": "analyze-ticket",
      "runIf": "state.plan_status !== 'found'",
      "stateReads": ["ticket_identifier", "ticket_url", "ticket_title"],
      "stateWrites": ["needs_questions"],
      "mockStateWrites": [["needs_questions", "false"]]
    },
    {
      "id": "ask-questions",
      "type": "claude-tui",
      "skill": "ask-questions",
      "runIf": "state.needs_questions === 'true'",
      "stateReads": ["ticket_identifier", "ticket_url"],
      "stateWrites": [],
      "mockStateWrites": []
    },
    {
      "id": "implement",
      "type": "claude-tui",
      "skill": "implement",
      "stateReads": ["branch", "ticket_identifier"]
    },
    {
      "id": "quality-loop",
      "type": "loop",
      "maxIterations": 5,
      "exitCondition": "state.review_status === 'approved'",
      "steps": [
        {
          "id": "checks",
          "type": "script",
          "script": "scripts/run-checks.sh",
          "stateWrites": ["check_status"]
        },
        {
          "id": "review",
          "type": "claude-tui",
          "skill": "review-fleet",
          "stateWrites": ["review_status", "review_findings"]
        },
        {
          "id": "fix",
          "type": "claude-tui",
          "skill": "implement",
          "runIf": "state.review_status === 'needs_fix'",
          "stateReads": ["review_findings"]
        }
      ]
    },
    {
      "id": "wrapup",
      "type": "claude-tui",
      "skill": "commit-and-pr",
      "stateReads": ["branch", "ticket_url", "api_tunnel_url", "portal_url", "ho_url"],
      "stateWrites": ["pr_number"]
    }
  ]
}
