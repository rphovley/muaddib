{
  "name": "feature",
  "services": [
    { "name": "servers", "script": "services/start-servers.sh", "readyEvent": "tunnel_ready" },
    { "name": "webhook", "script": "services/watch-feedback.sh" }
  ],
  "workflow": [
    {
      "id": "gather-context",
      "type": "claude-tui",
      "skill": "gather-context",
      "stateWrites": ["branch", "ticket_url"]
    },
    {
      "id": "implement",
      "type": "claude-tui",
      "skill": "implement",
      "stateReads": ["branch"]
    },
    {
      "id": "quality-loop",
      "type": "loop",
      "maxIterations": 5,
      "exitCondition": "state.review_status === 'approved'",
      "steps": [
        {
          "id": "checks",
          "type": "script",
          "script": "scripts/run-checks.sh",
          "stateWrites": ["check_status"]
        },
        {
          "id": "review",
          "type": "claude-tui",
          "skill": "review-fleet",
          "runIf": "state.check_status === 'pass'",
          "stateWrites": ["review_status", "review_findings"]
        },
        {
          "id": "fix",
          "type": "claude-tui",
          "skill": "implement",
          "runIf": "state.review_status === 'needs_fix'",
          "stateReads": ["review_findings"]
        }
      ]
    },
    {
      "id": "wrapup",
      "type": "claude-tui",
      "skill": "commit-and-pr",
      "stateReads": ["branch", "ticket_url", "api_tunnel_url", "portal_url", "ho_url"],
      "stateWrites": ["pr_number"]
    }
  ]
}
