{
  "name": "plan",
  "skipWatching": true,
  "services": [],
  "workflow": [
    {
      "id": "fetch-ticket",
      "type": "script",
      "script": "scripts/fetch-ticket.js",
      "stateWrites": ["ticket_identifier", "ticket_url", "ticket_title", "plan_status"]
    },
    {
      "id": "analyze-ticket",
      "type": "claude-tui",
      "skill": "analyze-ticket",
      "runIf": "state.plan_status !== 'found'",
      "stateReads": ["ticket_identifier", "ticket_url", "ticket_title"],
      "stateWrites": ["needs_questions"]
    },
    {
      "id": "ask-questions",
      "type": "claude-tui",
      "skill": "ask-questions",
      "runIf": "state.needs_questions === 'true'",
      "stateReads": ["ticket_identifier", "ticket_url"],
      "stateWrites": []
    }
  ]
}
