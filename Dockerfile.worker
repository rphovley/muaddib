# Worker image: an isolated, all-commands-enabled Claude Code session.
# Extends muaddib-base:latest (toolchain layer). Build context is repo root.
# Build both images with: npm run muaddib:build
# Or use a project's .muaddib/Dockerfile.worker to override this file.
FROM muaddib-base:latest

# --- Pre-install project dependencies (Linux-native, layer-cached) -----------
# Copy ONLY the manifests first so this layer re-runs only when lockfiles change.
# Each baked lockfile is stashed under ~/.deps-lock for drift detection at startup.
WORKDIR /home/worker/repo
COPY --chown=worker:worker projects/api/package.json          projects/api/package-lock.json          projects/api/
COPY --chown=worker:worker projects/portal/package.json       projects/portal/package-lock.json       projects/portal/
COPY --chown=worker:worker projects/homeowner/package.json    projects/homeowner/package-lock.json    projects/homeowner/
COPY --chown=worker:worker projects/app_install/package.json  projects/app_install/package-lock.json  projects/app_install/
COPY --chown=worker:worker .muaddib.json .muaddib.json
ARG MUADDIB_PROJECTS="projects/api projects/portal projects/homeowner projects/app_install"
RUN for p in $MUADDIB_PROJECTS; do \
        echo "== installing deps: $p ==" && npm --prefix "$p" ci \
        && mkdir -p "/home/worker/.deps-lock/$p" \
        && cp "$p/package-lock.json" "/home/worker/.deps-lock/$p/package-lock.json" ; \
    done

# Bake the full repo source + .git into the image so startup only needs a
# fast `git fetch --depth 1` (just the delta since the image was built) instead
# of cloning from GitHub from scratch. node_modules is excluded via dockerignore.
COPY --chown=worker:worker . /home/worker/repo/

WORKDIR /home/worker
COPY --chown=worker:worker muaddib/claude/settings.json /home/worker/.claude/settings.json
COPY --chown=worker:worker muaddib/claude/skills/ /home/worker/.claude/skills/
# Pre-seed onboarding state so claude skips the theme picker / welcome / trust
# dialog and goes straight to the task. The entrypoint's `claude mcp add` merges
# mcpServers into this same file at runtime.
COPY --chown=worker:worker muaddib/claude/claude.json /home/worker/.claude.json
COPY --chown=worker:worker muaddib/claude/tmux.conf /home/worker/.tmux.conf
COPY --chown=worker:worker muaddib/worker-entrypoint.sh /home/worker/worker-entrypoint.sh

ENTRYPOINT ["bash", "/home/worker/worker-entrypoint.sh"]
